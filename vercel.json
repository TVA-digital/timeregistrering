{
  "installCommand": "npm install",
  "buildCommand": "npm run build -w shared && npm run build -w server",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/health", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "server/dist/**"
    }
  }
}
